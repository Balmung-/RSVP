# --- Core ---
# Postgres. For Railway, set to ${{Postgres.DATABASE_URL}} as a reference var.
# For local dev with docker-compose: postgresql://einai:einai@localhost:5432/einai
DATABASE_URL="postgresql://user:pass@host:5432/einai?sslmode=require"
APP_URL="http://localhost:3000"
APP_BRAND="Einai"
APP_TIMEZONE="Asia/Riyadh"           # fixed-offset only: Asia/Riyadh | Asia/Dubai | Africa/Cairo | UTC

# --- Auth ---
# On the very first login the app seeds an admin user `admin@local` with this
# password if no users exist yet. After that, users are managed at /users and
# ADMIN_PASSWORD is ignored.
ADMIN_PASSWORD="change-me"
SESSION_SECRET="replace-with-32-byte-random"

# --- Nafath SSO (optional) ---
# Wire when you want to replace password sign-in with the Saudi national SSO.
# The stubs at /api/auth/nafath/{start,callback} are ready; the integration
# itself is the only thing left to implement.
NAFATH_CLIENT_ID=""
NAFATH_CLIENT_SECRET=""
NAFATH_AUTH_URL=""
NAFATH_TOKEN_URL=""
NAFATH_JWKS_URL=""

# --- Observability ---
HEALTH_REQUIRE_DB="false"            # flip to "true" once DATABASE_URL is wired, so Railway catches DB outages

# --- Server action hardening (optional) ---
# Comma-separated origins that may POST server actions. Defaults to same-origin.
ALLOWED_ORIGINS=""

# --- Webhook (delivery status inbound) ---
# Leave empty to disable /api/webhooks/delivery. HMAC-SHA256 of the raw body,
# hex-encoded, must match x-signature header. Generate: openssl rand -hex 32.
WEBHOOK_SIGNING_SECRET=""

# --- Cron / scheduled stages ---
# Bearer token required by /api/cron/tick. Any scheduler can call the endpoint
# on a minute-ish cadence (Railway cron, Vercel cron, cron-job.org, GH Actions).
# Leave empty to disable scheduled stages. Generate: openssl rand -hex 32.
CRON_SECRET=""

# --- Teams (optional) ---
# When "true", the Teams feature is exposed: admins can create org units,
# assign members, and scope campaigns. For single-desk tenants, leave unset.
TEAMS_ENABLED=""

# --- Inbound reply handling ---
# Reply-To on outgoing invitations becomes rsvp+<token>@<this-domain>.
# Requires MX records on that domain pointing at an inbound-parse
# service (SendGrid Inbound Parse, Mailgun Routes, Postmark Inbound,
# AWS SES). Empty disables reply-to-RSVP; sending still works.
INBOUND_EMAIL_DOMAIN=""

# Shared bearer token required on POSTs to /api/webhooks/inbound/*.
# Send it as the "x-inbound-secret" header (or ?key= query param for
# SMS providers that can't add custom headers). Generate with
# `openssl rand -hex 32`.
INBOUND_WEBHOOK_SECRET=""

# When a reply is confidently parsed as attending/declined/stop AND we
# can match the sender to a known invitee, send a one-line bilingual
# acknowledgment back on the same channel. Set to "false" to disable.
INBOUND_AUTO_ACK="true"

# --- Approval workflow ---
# Sends touching more than this many recipients require an admin to
# approve them at /approvals. Admins bypass the gate. Default 100.
APPROVAL_THRESHOLD="100"

# --- Daily digest ---
# When true, /api/cron/tick also fires a once-per-day deliverability
# summary to every admin at DIGEST_HOUR (APP_TIMEZONE local). Idempotent
# via an eventLog row keyed on the local date, so duplicate cron calls
# are safe. Opt-in — leave unset on quiet offices.
DELIVERABILITY_DIGEST=""
DIGEST_HOUR="7"

# --- Email provider (choose one, leave others blank) ---
EMAIL_PROVIDER="stub"                # stub | sendgrid | resend
EMAIL_FROM="no-reply@example.gov.sa"
EMAIL_FROM_NAME="Protocol Office"
SENDGRID_API_KEY=""
RESEND_API_KEY=""

# --- SMS provider ---
SMS_PROVIDER="stub"                  # stub | twilio | whatsapp | unifonic | msegat
SMS_SENDER_ID="GOV"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
# WhatsApp via Twilio reuses the same SID + auth token. Set WHATSAPP_FROM
# to the E.164 number enrolled in your WhatsApp Business sender profile
# (no "whatsapp:" prefix — we add it when dispatching).
WHATSAPP_FROM=""
UNIFONIC_APP_SID=""
UNIFONIC_SENDER_NAME=""
MSEGAT_API_KEY=""
MSEGAT_USERNAME=""

# --- Locale ---
DEFAULT_LOCALE="en"                  # en | ar
DEFAULT_COUNTRY="SA"
