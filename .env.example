# --- Core ---
# Postgres. For Railway, set to ${{Postgres.DATABASE_URL}} as a reference var.
# For local dev with docker-compose: postgresql://einai:einai@localhost:5432/einai
DATABASE_URL="postgresql://user:pass@host:5432/einai?sslmode=require"
APP_URL="http://localhost:3000"
APP_BRAND="Einai"
APP_TIMEZONE="Asia/Riyadh"           # fixed-offset only: Asia/Riyadh | Asia/Dubai | Africa/Cairo | UTC

# --- Auth (admin) ---
ADMIN_PASSWORD="change-me"
SESSION_SECRET="replace-with-32-byte-random"

# --- Observability ---
HEALTH_REQUIRE_DB="false"            # flip to "true" once DATABASE_URL is wired, so Railway catches DB outages

# --- Server action hardening (optional) ---
# Comma-separated origins that may POST server actions. Defaults to same-origin.
ALLOWED_ORIGINS=""

# --- Webhook (delivery status inbound) ---
# Leave empty to disable /api/webhooks/delivery. HMAC-SHA256 of the raw body,
# hex-encoded, must match x-signature header. Generate: openssl rand -hex 32.
WEBHOOK_SIGNING_SECRET=""

# --- Cron / scheduled stages ---
# Bearer token required by /api/cron/tick. Any scheduler can call the endpoint
# on a minute-ish cadence (Railway cron, Vercel cron, cron-job.org, GH Actions).
# Leave empty to disable scheduled stages. Generate: openssl rand -hex 32.
CRON_SECRET=""

# --- Email provider (choose one, leave others blank) ---
EMAIL_PROVIDER="stub"                # stub | sendgrid | resend
EMAIL_FROM="no-reply@example.gov.sa"
EMAIL_FROM_NAME="Protocol Office"
SENDGRID_API_KEY=""
RESEND_API_KEY=""

# --- SMS provider ---
SMS_PROVIDER="stub"                  # stub | twilio | unifonic | msegat
SMS_SENDER_ID="GOV"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
UNIFONIC_APP_SID=""
UNIFONIC_SENDER_NAME=""
MSEGAT_API_KEY=""
MSEGAT_USERNAME=""

# --- Locale ---
DEFAULT_LOCALE="en"                  # en | ar
DEFAULT_COUNTRY="SA"
