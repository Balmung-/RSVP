// Einai RSVP — data core.
// Small surface, explicit relations. Postgres in dev + prod (Neon / RDS / Azure).
// For a zero-dependency local run, flip provider to "sqlite" and set
// DATABASE_URL="file:./dev.db" — schema below is compatible with both.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A Campaign is the top-level container. Long-running, reusable.
model Campaign {
  id            String     @id @default(cuid())
  name          String
  description   String?
  eventAt       DateTime?
  venue         String?
  locale        String     @default("en") // primary locale (en | ar)
  rsvpDeadline  DateTime?
  status        String     @default("draft") // draft | active | closed | archived
  templateEmail String? // optional custom email body (liquid-lite)
  templateSms   String? // optional custom sms body
  subjectEmail  String?
  // P13 — WhatsApp template discipline. Business-initiated
  // conversations on Meta Cloud API MUST start from a pre-approved
  // template; free-form session text is only valid inside the 24h
  // reply window, which a campaign's initial send can't assume.
  // These three fields capture everything a send-time planner needs
  // to build a `WhatsAppTemplateMessage`:
  //   - name:      template id registered with the BSP (e.g.
  //                "rsvp_invitation_v1"). Meta enforces exact-match.
  //   - language:  BCP-47 tag Meta accepts (e.g. "ar", "en_US").
  //   - variables: JSON-encoded positional expression array. Each
  //                entry is an interpolation string (e.g. "{{name}}",
  //                "{{venue}}") resolved against the invitee's vars
  //                map using the same `render` helper that powers
  //                templateEmail / templateSms. The resolved strings
  //                are passed through to Meta as the template's
  //                positional BODY parameters, in order.
  // Nullable: a campaign that hasn't been configured for WhatsApp
  // fails fast at send time with reason="no_template" rather than
  // accidentally sending an empty template.
  templateWhatsAppName      String?
  templateWhatsAppLanguage  String?
  templateWhatsAppVariables String? // JSON array of expression strings
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  // Branding (optional overrides for RSVP page + email hero).
  brandColor    String?   // hex, e.g. "#0a6e3d"
  brandLogoUrl  String?
  brandHeroUrl  String?

  // Optional team scoping. null = office-wide.
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  invitees      Invitee[]
  invitations   Invitation[]
  responses     Response[]
  stages        CampaignStage[]
  questions     CampaignQuestion[]
  attachments   CampaignAttachment[]
  eventOptions  EventOption[]
  approvals     SendApproval[]

  @@index([status])
  @@index([teamId])
}

// Per-campaign custom question asked on the RSVP page.
model CampaignQuestion {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  prompt      String
  kind        String   // short_text | long_text | single_select | multi_select | number | boolean
  required    Boolean  @default(false)
  options     String?  // newline-separated, for single_select / multi_select
  showWhen    String   @default("always") // always | attending | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answers     Answer[]

  @@index([campaignId, order])
}

// Invitee's answer to a question. One per (response, question).
model Answer {
  id          String             @id @default(cuid())
  responseId  String
  response    Response           @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId  String
  question    CampaignQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value       String             // single string for everything; multi-select → newline-joined

  @@unique([responseId, questionId])
  @@index([questionId])
}

// Attachment shown on the RSVP page + linked in email/SMS. URL-only for now —
// hosting lives with the tenant (S3, gov doc server, whatever).
model CampaignAttachment {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  label       String
  url         String
  kind        String   @default("file") // file | map | agenda | parking
  createdAt   DateTime @default(now())

  @@index([campaignId, order])
}

// Optional date alternatives — when populated, invitee picks one on RSVP.
model EventOption {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int       @default(0)
  label       String?
  startsAt    DateTime
  endsAt      DateTime?
  venue       String?
  createdAt   DateTime  @default(now())
  responses   Response[]

  @@index([campaignId, order])
}

// A scheduled touchpoint within a campaign. Stages stack into a flow:
// invite → reminder → last_call → thanks. Each stage has its own audience,
// channels, and (optional) template overrides. The dispatcher wakes any stage
// whose scheduledFor is in the past and whose status is still "pending".
model CampaignStage {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kind          String    // invite | reminder | last_call | thanks | custom
  name          String?
  order         Int       @default(0)
  scheduledFor  DateTime
  channels      String    @default("email,sms") // comma-sep subset of [email, sms]
  audience      String    @default("all")       // all | non_responders | attending | declined
  subjectEmail  String?
  templateEmail String?
  templateSms   String?
  status        String    @default("pending")   // pending | running | completed | failed | skipped
  startedAt     DateTime?
  completedAt   DateTime?
  sentCount     Int       @default(0)
  skippedCount  Int       @default(0)
  failedCount   Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([campaignId, order])
  @@index([status, scheduledFor])
}

// An Invitee is a person. Phone/email are normalized and unique per campaign.
model Invitee {
  id             String      @id @default(cuid())
  campaignId     String
  campaign       Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  fullName       String
  title          String?     // honorific / rank
  organization   String?
  email          String?     // normalized lowercase
  phoneE164      String?     // +9665XXXXXXXX
  locale         String?     // overrides campaign locale
  tags           String?     // comma-separated tags
  rsvpToken      String      @unique
  guestsAllowed  Int         @default(0)
  notes          String?
  dedupKey       String      // hash(email|phoneE164)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  invitations    Invitation[]
  response       Response?
  inboundMessages InboundMessage[]

  @@unique([campaignId, dedupKey])
  @@index([campaignId, phoneE164])
  @@index([campaignId, email])
  @@index([contactId])
}

// A delivery attempt on a specific channel (email or sms).
model Invitation {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inviteeId   String
  invitee     Invitee   @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  channel     String    // "email" | "sms"
  status      String    @default("queued") // queued | sent | delivered | failed | bounced
  providerId  String?   // id returned by the upstream API
  error       String?
  payload     String?   // rendered body snapshot
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([campaignId, channel, status])
  @@index([providerId])
  // Supports the daily digest and /deliverability queries that scan all
  // failing/bounced invitations in the last N days across every campaign.
  @@index([status, createdAt])
}

// A Response captures the invitee's RSVP answer. One per invitee.
model Response {
  id             String       @id @default(cuid())
  campaignId     String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inviteeId      String       @unique
  invitee        Invitee      @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  attending      Boolean
  guestsCount    Int          @default(0)
  guestNames     String?      // newline-joined list of plus-one names
  message        String?
  ip             String?
  userAgent      String?
  respondedAt    DateTime     @default(now())
  eventOptionId  String?
  eventOption    EventOption? @relation(fields: [eventOptionId], references: [id], onDelete: SetNull)
  answers        Answer[]
  checkedInAt    DateTime?
  checkedInBy    String?      // actor user id

  @@index([campaignId, attending])
  @@index([checkedInAt])
}

// Event log — every significant action, for audit/tracing.
model EventLog {
  id         String   @id @default(cuid())
  kind       String   // invite.sent, invite.delivered, rsvp.submitted, import.completed, ...
  refType    String?  // campaign | invitee | invitation | stage | user
  refId      String?
  actorId    String?  // user who performed the action; null for system / public flows
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  data       String?  // JSON blob
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
  @@index([actorId, createdAt])
  @@index([refType, refId, createdAt])
}

// --- Global address book ---------------------------------------

// A Contact is a person the office invites. One canonical record per
// human — the same ambassador invited to 30 events lives once here.
// Invitee rows can reference a Contact for their base fields, but
// still carry campaign-specific overrides (guest count, per-campaign
// notes).
model Contact {
  id              String   @id @default(cuid())
  fullName        String
  title           String?
  organization    String?
  email           String?
  phoneE164       String?
  preferredLocale String?  // en | ar
  vipTier         String   @default("standard") // royal | minister | vip | standard
  tags            String?
  dietary         String?
  dress           String?
  securityNotes   String?
  notes           String?
  dedupKey        String   @unique
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  invitees        Invitee[]

  @@index([vipTier])
  @@index([fullName])
  @@index([email])
  @@index([phoneE164])
}

// --- Files -----------------------------------------------------

// DB-backed file storage. Blob in Postgres — simple, portable, survives
// any redeploy. Small files only (logos, hero images, agenda PDFs up to a
// few MB). If you outgrow it, swap the contents column for an S3 pointer
// without changing callers.
model FileUpload {
  id          String   @id @default(cuid())
  filename    String
  contentType String
  size        Int
  contents    Bytes
  uploadedBy  String?
  createdAt   DateTime @default(now())

  ingests     FileIngest[]

  @@index([createdAt])
}

// Extracted text + provenance for an uploaded file. One-to-one with
// FileUpload today (UNIQUE on fileUploadId) — the row is created
// lazily when ingestion starts. Status is a narrow FSM:
//   pending     — row exists, extractor not yet run
//   extracted   — extractedText is populated (or empty for zero-byte)
//   failed      — extractionError explains why; text is null
//   unsupported — kind is known-unhandled (image, binary); no error
// bytesExtracted is the UTF-8 length of extractedText; useful for
// budget decisions before we ever feed text into the model.
model FileIngest {
  id              String     @id @default(cuid())
  fileUploadId    String     @unique
  fileUpload      FileUpload @relation(fields: [fileUploadId], references: [id], onDelete: Cascade)
  status          String     @default("pending")
  kind            String
  extractedText   String?
  extractionError String?
  bytesExtracted  Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
}

// --- Approvals -------------------------------------------------

// Gate large sends behind admin sign-off. When an editor triggers
// sendCampaign and the recipient count exceeds APPROVAL_THRESHOLD, we
// persist a SendApproval row instead of firing. Admins approve from
// /approvals and the send runs with the stored params.
model SendApproval {
  id             String    @id @default(cuid())
  campaignId     String
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel        String    // email | sms | both
  recipientCount Int
  requestedBy    String
  note           String?
  status         String    @default("pending") // pending | approved | rejected | expired
  decidedBy      String?
  decidedAt      DateTime?
  decisionNote   String?
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
  @@index([campaignId])
}

// --- Templates library -----------------------------------------

// Reusable outbound message templates, office-wide. Operators load one
// into a campaign or stage to seed the subject + body. Tagging lets
// them filter by kind ("national-day", "ramadan"). Locale-aware: a
// template is either en or ar.
model Template {
  id          String   @id @default(cuid())
  name        String
  kind        String   // email | sms
  locale      String   @default("en") // en | ar
  subject     String?  // email only
  body        String
  tags        String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([kind, archivedAt])
  @@index([locale])
}

// --- Inbound / compliance --------------------------------------

// Email or SMS replies captured by our inbound webhooks. We extract
// the rsvp token from the address (rsvp+<token>@inbound-domain for
// email, or body/phone match for SMS), classify intent (yes/no/stop/
// auto), and either apply the response automatically or route to the
// needs-review queue.
model InboundMessage {
  id           String   @id @default(cuid())
  channel      String   // email | sms
  providerId   String?  // message-id or twilio SID
  fromAddress  String
  toAddress    String?
  subject      String?
  body         String
  rawHeaders   String?
  token        String?
  inviteeId    String?
  invitee      Invitee? @relation(fields: [inviteeId], references: [id], onDelete: SetNull)
  intent       String   @default("unknown") // attending | declined | stop | autoreply | unknown
  status       String   @default("new")     // new | processed | needs_review | ignored
  note         String?
  processedAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
  @@index([inviteeId])
}

// One row per email/phone that has opted out. Sender respects this at
// send time; unsubscribed recipients are skipped silently.
model Unsubscribe {
  id        String   @id @default(cuid())
  email     String?  @unique
  phoneE164 String?  @unique
  reason    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phoneE164])
}

// --- Teams -----------------------------------------------------

// Optional org unit. When TEAMS_ENABLED is on, admins carve the office
// into desks (Royal Protocol, Media, International Relations…). A
// campaign can be office-wide (teamId = null) or scoped to a team.
// Membership is many-to-many; users can belong to multiple teams.
model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  color       String?
  description String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships    TeamMembership[]
  campaigns      Campaign[]
  oauthAccounts  OAuthAccount[]

  @@index([slug])
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("member") // lead | member | guest
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

// --- Conversational surface ------------------------------------

// A ChatSession is one conversational thread between an operator and
// the assistant. Threads accumulate messages (user / assistant / tool
// call / tool result) and render directives — typed payloads the
// client expands into fixed UI components (CampaignList, CampaignCard,
// ConfirmSend, …). Sessions are owned by a single user; team scope on
// individual tool calls is re-resolved server-side on every request,
// never trusted from the model's output.
model ChatSession {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String?
  archivedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]
  widgets    ChatWidget[]

  @@index([userId, updatedAt])
  @@index([userId, archivedAt])
}

// One message in a ChatSession. `role` = user | assistant | tool. For
// tool rows, `toolName` + `toolInput` + `toolOutput` are populated and
// `content` holds a short human-readable summary. `renderDirective` is
// a typed JSON payload ({ kind, props }) the client matches against a
// fixed registry; unknown kinds are dropped client-side. `isError`
// is a load-bearing flag on tool rows: it's forwarded to
// ToolResultBlockParam.is_error when the transcript is replayed to
// Anthropic on later turns, so a stored failure (e.g.
// `needs_confirmation`, invalid input, handler throw) stays marked
// as an error rather than being replayed as a successful payload.
// Default false is a safe no-op for user/assistant rows and for
// tool rows that completed successfully.
model ChatMessage {
  id               String      @id @default(cuid())
  sessionId        String
  session          ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role             String      // user | assistant | tool
  content          String      @default("")
  toolName         String?
  toolInput        String?     // JSON
  toolOutput       String?     // JSON
  renderDirective  String?     // JSON
  isError          Boolean     @default(false)
  // Single-use anchor for destructive confirmations (Push 7 fix).
  // When /api/chat/confirm/[messageId] atomically claims a
  // propose_send tool row for dispatch, this timestamp is set via
  // `updateMany({where: {..., confirmedAt: null}})`. A second POST
  // against the same messageId races for the same row and loses;
  // the second request audits `ai.denied.send_campaign` with
  // reason=already_confirmed and returns 409. On a dispatched-but-
  // refused path (status_not_sendable / send_in_flight / forbidden
  // / not_found — all of which refuse BEFORE any send fan-out) the
  // route releases the claim so the operator can retry without
  // hitting a stale already_confirmed. Nullable because only tool
  // rows with toolName=propose_send ever set it.
  confirmedAt      DateTime?
  createdAt        DateTime    @default(now())

  // Widgets whose `sourceMessageId` points at this row. SetNull on
  // the FK so deleting a message doesn't cascade through the
  // workspace — the widget survives with a dangling source, which
  // is the operator-friendly behavior (a stale tool invocation
  // shouldn't wipe the dashboard state built from it).
  sourcedWidgets   ChatWidget[]

  @@index([sessionId, createdAt])
}

// A ChatWidget is a persisted piece of workspace UI state tied to a
// ChatSession. The current /chat surface renders directives inline
// inside assistant turns — i.e. the UI disappears into the
// transcript and has to be "replayed" every load. W1 of the workspace
// pivot moves the high-value surfaces (campaign list, contact table,
// confirm cards, etc.) onto a side-by-side dashboard whose state
// persists across reloads and is updated in-place by follow-up
// tools rather than re-appended per turn.
//
// Why its own table (not a JSON blob on ChatSession):
//   - We query by (sessionId, slot) and upsert by (sessionId,
//     widgetKey). Both are cheap with per-row indexes; both are
//     painful with a single opaque JSON column where every update
//     is read-modify-write on the whole dashboard.
//   - Per-row timestamps let the client sort / highlight recent
//     changes without a separate activity feed.
//   - Cascade semantics on delete mean archiving / wiping a session
//     wipes its dashboard with zero manual cleanup.
//
// `widgetKey` is a CALLER-CHOSEN stable identifier that defines
// upsert semantics within a session — e.g. `list_campaigns` tool
// writes to `widgetKey="campaign_list:active"` so re-asking updates
// the existing widget instead of appending a second copy. The key
// is unique WITHIN a session; two sessions can both own a widget
// called "campaign_list:active" without collision.
//
// `kind` is the renderer discriminator, validated against a closed
// registry at the persistence boundary (see
// `src/lib/ai/widget-validate.ts`) so a rogue tool can't store a
// malformed shape the client then renders. Same trust model as
// `ChatMessage.renderDirective`.
//
// `slot` is one of `summary | primary | secondary | action` — the
// four dashboard regions W2 introduces. Stored as a string (rather
// than a Prisma enum) so adding a fifth slot doesn't require a
// migration; the validator is the gate.
//
// `props` is a JSON blob (stored as a string to match the
// ChatMessage.renderDirective convention + keep SQLite
// compatibility). Validated at the widget boundary — never trusted
// blindly on read.
//
// `order` is a small integer used to order widgets WITHIN a slot.
// Default 0; callers set it explicitly when fanning out multiple
// widgets to the same slot.
//
// `sourceMessageId` points at the tool ChatMessage row that
// produced this widget (when applicable). Optional + SetNull so
// the widget survives a deleted message; useful for the client UI
// to link back to the originating turn without blocking DELETE.
model ChatWidget {
  id               String       @id @default(cuid())
  sessionId        String
  session          ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  widgetKey        String
  kind             String
  slot             String
  // JSON payload matching the kind's declared props shape. Always
  // passed through `validateWidget(...)` before write AND again on
  // read to defend against schema drift.
  props            String
  order            Int          @default(0)
  // Optional link to the tool message that produced this widget.
  sourceMessageId  String?
  sourceMessage    ChatMessage? @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Upsert contract: (sessionId, widgetKey) is the stable identity
  // callers target. A second write to the same key UPDATES in place;
  // a remove() by the same key wipes exactly that widget.
  @@unique([sessionId, widgetKey])
  // Listing by (sessionId, slot, order) is the dashboard render
  // path; add an index so it stays O(log n) on hot sessions.
  @@index([sessionId, slot, order])
}

// --- Identity --------------------------------------------------

// Admin users. One row per human. `passwordHash` is nullable for SSO-only
// users; `role` drives every capability check in lib/auth.ts.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  mustChangePassword Boolean @default(false)
  totpSecret   String?
  totpConfirmedAt DateTime?
  fullName     String?
  role         String    @default("viewer") // admin | editor | viewer
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  sessions     Session[]
  eventLog     EventLog[]
  teams        TeamMembership[]
  chatSessions ChatSession[]
  oauthAccounts OAuthAccount[] @relation("OAuthConnectedBy")

  @@index([email])
}

// Server-side session. The cookie carries the id + HMAC; this row is the
// authority (allows revocation + audit). Expired rows are pruned lazily.
model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// --- OAuth accounts ---------------------------------------------
//
// Stored credentials for third-party accounts the operator connects for
// outbound sending (Phase B1: Gmail send). One row per (provider, team)
// pair — a team picks which Gmail Workspace mailbox to send from; office-
// wide campaigns (teamId = null) use the row with `teamId IS NULL`.
//
// Both `accessTokenEnc` and `refreshTokenEnc` are AES-256-GCM ciphertexts
// produced by `src/lib/secrets.ts`. The envelope format is
// `v1.<iv>.<authTag>.<ciphertext>` (all base64) so a future key rotation
// can add `v2` without disturbing rows at rest. Plaintext tokens never
// touch Prisma.
//
// `scopes` is the space-separated list Google actually granted — always
// re-read from the token response, never echoed from the authorize URL,
// because Google may grant a subset (e.g. if the user unchecks a
// non-required scope on the consent screen).
//
// `connectedBy` is the operator who completed the OAuth dance. Useful
// for audit trails ("who granted this mailbox to the office") and for
// revocation flows that want to notify the granter.
model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String   // "google" — open-set for future providers
  teamId            String?
  team              Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  googleEmail       String   // lowercased address from the userinfo response
  accessTokenEnc    String   // AES-256-GCM envelope — see src/lib/secrets.ts
  refreshTokenEnc   String   // AES-256-GCM envelope
  tokenExpiresAt    DateTime
  scopes            String   // space-separated granted scopes
  connectedByUserId String
  connectedBy       User     @relation("OAuthConnectedBy", fields: [connectedByUserId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // One account per (provider, team). `teamId IS NULL` is the office-wide
  // slot — Postgres treats NULLs as distinct by default, so this unique
  // DOESN'T enforce "one office-wide row" on its own. Two mitigations:
  //   1. The callback route does find-first + update-or-create + a
  //      deleteMany(id != winner) inside one transaction, so every
  //      successful connect collapses the (provider, teamId=null)
  //      set back to one row.
  //   2. The Gmail send adapter resolves the mailbox with `orderBy
  //      updatedAt desc` (not an arbitrary findFirst), so if a
  //      transient duplicate does survive two truly concurrent
  //      commits it still routes sends to the freshest row.
  // Leftover duplicates are no longer a "harmless GC target" post-B2 —
  // they'd cause nondeterministic send routing. The cleanup + ordering
  // above is what prevents that.
  @@unique([provider, teamId])
  @@index([provider])
}
