// Einai RSVP — data core.
// Small surface, explicit relations. Postgres in dev + prod (Neon / RDS / Azure).
// For a zero-dependency local run, flip provider to "sqlite" and set
// DATABASE_URL="file:./dev.db" — schema below is compatible with both.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A Campaign is the top-level container. Long-running, reusable.
model Campaign {
  id            String     @id @default(cuid())
  name          String
  description   String?
  eventAt       DateTime?
  venue         String?
  locale        String     @default("en") // primary locale (en | ar)
  rsvpDeadline  DateTime?
  status        String     @default("draft") // draft | active | closed | archived
  templateEmail String? // optional custom email body (liquid-lite)
  templateSms   String? // optional custom sms body
  subjectEmail  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  // Branding (optional overrides for RSVP page + email hero).
  brandColor    String?   // hex, e.g. "#0a6e3d"
  brandLogoUrl  String?
  brandHeroUrl  String?

  // Optional team scoping. null = office-wide.
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  invitees      Invitee[]
  invitations   Invitation[]
  responses     Response[]
  stages        CampaignStage[]
  questions     CampaignQuestion[]
  attachments   CampaignAttachment[]
  eventOptions  EventOption[]

  @@index([status])
  @@index([teamId])
}

// Per-campaign custom question asked on the RSVP page.
model CampaignQuestion {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  prompt      String
  kind        String   // short_text | long_text | single_select | multi_select | number | boolean
  required    Boolean  @default(false)
  options     String?  // newline-separated, for single_select / multi_select
  showWhen    String   @default("always") // always | attending | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answers     Answer[]

  @@index([campaignId, order])
}

// Invitee's answer to a question. One per (response, question).
model Answer {
  id          String             @id @default(cuid())
  responseId  String
  response    Response           @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId  String
  question    CampaignQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value       String             // single string for everything; multi-select → newline-joined

  @@unique([responseId, questionId])
  @@index([questionId])
}

// Attachment shown on the RSVP page + linked in email/SMS. URL-only for now —
// hosting lives with the tenant (S3, gov doc server, whatever).
model CampaignAttachment {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  label       String
  url         String
  kind        String   @default("file") // file | map | agenda | parking
  createdAt   DateTime @default(now())

  @@index([campaignId, order])
}

// Optional date alternatives — when populated, invitee picks one on RSVP.
model EventOption {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int       @default(0)
  label       String?
  startsAt    DateTime
  endsAt      DateTime?
  venue       String?
  createdAt   DateTime  @default(now())
  responses   Response[]

  @@index([campaignId, order])
}

// A scheduled touchpoint within a campaign. Stages stack into a flow:
// invite → reminder → last_call → thanks. Each stage has its own audience,
// channels, and (optional) template overrides. The dispatcher wakes any stage
// whose scheduledFor is in the past and whose status is still "pending".
model CampaignStage {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kind          String    // invite | reminder | last_call | thanks | custom
  name          String?
  order         Int       @default(0)
  scheduledFor  DateTime
  channels      String    @default("email,sms") // comma-sep subset of [email, sms]
  audience      String    @default("all")       // all | non_responders | attending | declined
  subjectEmail  String?
  templateEmail String?
  templateSms   String?
  status        String    @default("pending")   // pending | running | completed | failed | skipped
  startedAt     DateTime?
  completedAt   DateTime?
  sentCount     Int       @default(0)
  skippedCount  Int       @default(0)
  failedCount   Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([campaignId, order])
  @@index([status, scheduledFor])
}

// An Invitee is a person. Phone/email are normalized and unique per campaign.
model Invitee {
  id             String      @id @default(cuid())
  campaignId     String
  campaign       Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  fullName       String
  title          String?     // honorific / rank
  organization   String?
  email          String?     // normalized lowercase
  phoneE164      String?     // +9665XXXXXXXX
  locale         String?     // overrides campaign locale
  tags           String?     // comma-separated tags
  rsvpToken      String      @unique
  guestsAllowed  Int         @default(0)
  notes          String?
  dedupKey       String      // hash(email|phoneE164)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  invitations    Invitation[]
  response       Response?
  inboundMessages InboundMessage[]

  @@unique([campaignId, dedupKey])
  @@index([campaignId, phoneE164])
  @@index([campaignId, email])
  @@index([contactId])
}

// A delivery attempt on a specific channel (email or sms).
model Invitation {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inviteeId   String
  invitee     Invitee   @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  channel     String    // "email" | "sms"
  status      String    @default("queued") // queued | sent | delivered | failed | bounced
  providerId  String?   // id returned by the upstream API
  error       String?
  payload     String?   // rendered body snapshot
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([campaignId, channel, status])
  @@index([providerId])
}

// A Response captures the invitee's RSVP answer. One per invitee.
model Response {
  id             String       @id @default(cuid())
  campaignId     String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inviteeId      String       @unique
  invitee        Invitee      @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  attending      Boolean
  guestsCount    Int          @default(0)
  guestNames     String?      // newline-joined list of plus-one names
  message        String?
  ip             String?
  userAgent      String?
  respondedAt    DateTime     @default(now())
  eventOptionId  String?
  eventOption    EventOption? @relation(fields: [eventOptionId], references: [id], onDelete: SetNull)
  answers        Answer[]
  checkedInAt    DateTime?
  checkedInBy    String?      // actor user id

  @@index([campaignId, attending])
  @@index([checkedInAt])
}

// Event log — every significant action, for audit/tracing.
model EventLog {
  id         String   @id @default(cuid())
  kind       String   // invite.sent, invite.delivered, rsvp.submitted, import.completed, ...
  refType    String?  // campaign | invitee | invitation | stage | user
  refId      String?
  actorId    String?  // user who performed the action; null for system / public flows
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  data       String?  // JSON blob
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
  @@index([actorId, createdAt])
}

// --- Global address book ---------------------------------------

// A Contact is a person the office invites. One canonical record per
// human — the same ambassador invited to 30 events lives once here.
// Invitee rows can reference a Contact for their base fields, but
// still carry campaign-specific overrides (guest count, per-campaign
// notes).
model Contact {
  id              String   @id @default(cuid())
  fullName        String
  title           String?
  organization    String?
  email           String?
  phoneE164       String?
  preferredLocale String?  // en | ar
  vipTier         String   @default("standard") // royal | minister | vip | standard
  tags            String?
  dietary         String?
  dress           String?
  securityNotes   String?
  notes           String?
  dedupKey        String   @unique
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  invitees        Invitee[]
  members         ContactGroupMember[]

  @@index([vipTier])
  @@index([fullName])
  @@index([email])
  @@index([phoneE164])
}

model ContactGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     ContactGroupMember[]

  @@index([name])
}

model ContactGroupMember {
  id         String       @id @default(cuid())
  groupId    String
  group      ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([groupId, contactId])
  @@index([contactId])
}

// --- Files -----------------------------------------------------

// DB-backed file storage. Blob in Postgres — simple, portable, survives
// any redeploy. Small files only (logos, hero images, agenda PDFs up to a
// few MB). If you outgrow it, swap the contents column for an S3 pointer
// without changing callers.
model FileUpload {
  id          String   @id @default(cuid())
  filename    String
  contentType String
  size        Int
  contents    Bytes
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// --- Approvals -------------------------------------------------

// Gate large sends behind admin sign-off. When an editor triggers
// sendCampaign and the recipient count exceeds APPROVAL_THRESHOLD, we
// persist a SendApproval row instead of firing. Admins approve from
// /approvals and the send runs with the stored params.
model SendApproval {
  id             String    @id @default(cuid())
  campaignId     String
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel        String    // email | sms | both
  recipientCount Int
  requestedBy    String
  note           String?
  status         String    @default("pending") // pending | approved | rejected | expired
  decidedBy      String?
  decidedAt      DateTime?
  decisionNote   String?
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
  @@index([campaignId])
}

// --- Templates library -----------------------------------------

// Reusable outbound message templates, office-wide. Operators load one
// into a campaign or stage to seed the subject + body. Tagging lets
// them filter by kind ("national-day", "ramadan"). Locale-aware: a
// template is either en or ar.
model Template {
  id          String   @id @default(cuid())
  name        String
  kind        String   // email | sms
  locale      String   @default("en") // en | ar
  subject     String?  // email only
  body        String
  tags        String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([kind, archivedAt])
  @@index([locale])
}

// --- Inbound / compliance --------------------------------------

// Email or SMS replies captured by our inbound webhooks. We extract
// the rsvp token from the address (rsvp+<token>@inbound-domain for
// email, or body/phone match for SMS), classify intent (yes/no/stop/
// auto), and either apply the response automatically or route to the
// needs-review queue.
model InboundMessage {
  id           String   @id @default(cuid())
  channel      String   // email | sms
  providerId   String?  // message-id or twilio SID
  fromAddress  String
  toAddress    String?
  subject      String?
  body         String
  rawHeaders   String?
  token        String?
  inviteeId    String?
  invitee      Invitee? @relation(fields: [inviteeId], references: [id], onDelete: SetNull)
  intent       String   @default("unknown") // attending | declined | stop | autoreply | unknown
  status       String   @default("new")     // new | processed | needs_review | ignored
  note         String?
  processedAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
  @@index([inviteeId])
}

// One row per email/phone that has opted out. Sender respects this at
// send time; unsubscribed recipients are skipped silently.
model Unsubscribe {
  id        String   @id @default(cuid())
  email     String?  @unique
  phoneE164 String?  @unique
  reason    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phoneE164])
}

// --- Teams -----------------------------------------------------

// Optional org unit. When TEAMS_ENABLED is on, admins carve the office
// into desks (Royal Protocol, Media, International Relations…). A
// campaign can be office-wide (teamId = null) or scoped to a team.
// Membership is many-to-many; users can belong to multiple teams.
model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  color       String?
  description String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships TeamMembership[]
  campaigns   Campaign[]

  @@index([slug])
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("member") // lead | member | guest
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

// --- Identity --------------------------------------------------

// Admin users. One row per human. `passwordHash` is nullable for SSO-only
// users; `role` drives every capability check in lib/auth.ts.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  mustChangePassword Boolean @default(false)
  fullName     String?
  role         String    @default("viewer") // admin | editor | viewer
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  sessions     Session[]
  eventLog     EventLog[]
  teams        TeamMembership[]

  @@index([email])
}

// Server-side session. The cookie carries the id + HMAC; this row is the
// authority (allows revocation + audit). Expired rows are pruned lazily.
model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
