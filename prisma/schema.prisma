// Einai RSVP — data core.
// Small surface, explicit relations. Postgres in dev + prod (Neon / RDS / Azure).
// For a zero-dependency local run, flip provider to "sqlite" and set
// DATABASE_URL="file:./dev.db" — schema below is compatible with both.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A Campaign is the top-level container. Long-running, reusable.
model Campaign {
  id            String     @id @default(cuid())
  name          String
  description   String?
  eventAt       DateTime?
  venue         String?
  locale        String     @default("en") // primary locale (en | ar)
  rsvpDeadline  DateTime?
  status        String     @default("draft") // draft | active | closed | archived
  templateEmail String? // optional custom email body (liquid-lite)
  templateSms   String? // optional custom sms body
  subjectEmail  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  // Branding (optional overrides for RSVP page + email hero).
  brandColor    String?   // hex, e.g. "#0a6e3d"
  brandLogoUrl  String?
  brandHeroUrl  String?

  invitees      Invitee[]
  invitations   Invitation[]
  responses     Response[]
  stages        CampaignStage[]
  questions     CampaignQuestion[]
  attachments   CampaignAttachment[]
  eventOptions  EventOption[]

  @@index([status])
}

// Per-campaign custom question asked on the RSVP page.
model CampaignQuestion {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  prompt      String
  kind        String   // short_text | long_text | single_select | multi_select | number | boolean
  required    Boolean  @default(false)
  options     String?  // newline-separated, for single_select / multi_select
  showWhen    String   @default("always") // always | attending | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answers     Answer[]

  @@index([campaignId, order])
}

// Invitee's answer to a question. One per (response, question).
model Answer {
  id          String             @id @default(cuid())
  responseId  String
  response    Response           @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId  String
  question    CampaignQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value       String             // single string for everything; multi-select → newline-joined

  @@unique([responseId, questionId])
  @@index([questionId])
}

// Attachment shown on the RSVP page + linked in email/SMS. URL-only for now —
// hosting lives with the tenant (S3, gov doc server, whatever).
model CampaignAttachment {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  label       String
  url         String
  kind        String   @default("file") // file | map | agenda | parking
  createdAt   DateTime @default(now())

  @@index([campaignId, order])
}

// Optional date alternatives — when populated, invitee picks one on RSVP.
model EventOption {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order       Int       @default(0)
  label       String?
  startsAt    DateTime
  endsAt      DateTime?
  venue       String?
  createdAt   DateTime  @default(now())
  responses   Response[]

  @@index([campaignId, order])
}

// A scheduled touchpoint within a campaign. Stages stack into a flow:
// invite → reminder → last_call → thanks. Each stage has its own audience,
// channels, and (optional) template overrides. The dispatcher wakes any stage
// whose scheduledFor is in the past and whose status is still "pending".
model CampaignStage {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kind          String    // invite | reminder | last_call | thanks | custom
  name          String?
  order         Int       @default(0)
  scheduledFor  DateTime
  channels      String    @default("email,sms") // comma-sep subset of [email, sms]
  audience      String    @default("all")       // all | non_responders | attending | declined
  subjectEmail  String?
  templateEmail String?
  templateSms   String?
  status        String    @default("pending")   // pending | running | completed | failed | skipped
  startedAt     DateTime?
  completedAt   DateTime?
  sentCount     Int       @default(0)
  skippedCount  Int       @default(0)
  failedCount   Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([campaignId, order])
  @@index([status, scheduledFor])
}

// An Invitee is a person. Phone/email are normalized and unique per campaign.
model Invitee {
  id             String      @id @default(cuid())
  campaignId     String
  campaign       Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fullName       String
  title          String?     // honorific / rank
  organization   String?
  email          String?     // normalized lowercase
  phoneE164      String?     // +9665XXXXXXXX
  locale         String?     // overrides campaign locale
  tags           String?     // comma-separated tags
  rsvpToken      String      @unique
  guestsAllowed  Int         @default(0)
  notes          String?
  dedupKey       String      // hash(email|phoneE164)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  invitations    Invitation[]
  response       Response?

  @@unique([campaignId, dedupKey])
  @@index([campaignId, phoneE164])
  @@index([campaignId, email])
}

// A delivery attempt on a specific channel (email or sms).
model Invitation {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inviteeId   String
  invitee     Invitee   @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  channel     String    // "email" | "sms"
  status      String    @default("queued") // queued | sent | delivered | failed | bounced
  providerId  String?   // id returned by the upstream API
  error       String?
  payload     String?   // rendered body snapshot
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([campaignId, channel, status])
  @@index([providerId])
}

// A Response captures the invitee's RSVP answer. One per invitee.
model Response {
  id             String       @id @default(cuid())
  campaignId     String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inviteeId      String       @unique
  invitee        Invitee      @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  attending      Boolean
  guestsCount    Int          @default(0)
  message        String?
  ip             String?
  userAgent      String?
  respondedAt    DateTime     @default(now())
  eventOptionId  String?
  eventOption    EventOption? @relation(fields: [eventOptionId], references: [id], onDelete: SetNull)
  answers        Answer[]

  @@index([campaignId, attending])
}

// Event log — every significant action, for audit/tracing.
model EventLog {
  id         String   @id @default(cuid())
  kind       String   // invite.sent, invite.delivered, rsvp.submitted, import.completed, ...
  refType    String?  // campaign | invitee | invitation
  refId      String?
  data       String?  // JSON blob
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
}
