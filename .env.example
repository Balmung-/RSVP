# --- Core ---
# Postgres. For Railway, set to ${{Postgres.DATABASE_URL}} as a reference var.
# For local dev with docker-compose: postgresql://einai:einai@localhost:5432/einai
DATABASE_URL="postgresql://user:pass@host:5432/einai?sslmode=require"
APP_URL="http://localhost:3000"
APP_BRAND="Einai"
APP_TIMEZONE="Asia/Riyadh"           # fixed-offset only: Asia/Riyadh | Asia/Dubai | Africa/Cairo | UTC

# --- Auth ---
# On the very first login the app seeds an admin user `admin@local` with this
# password if no users exist yet. After that, users are managed at /users and
# ADMIN_PASSWORD is ignored.
ADMIN_PASSWORD="change-me"
SESSION_SECRET="replace-with-32-byte-random"

# --- Nafath SSO (optional) ---
# Wire when you want to replace password sign-in with the Saudi national SSO.
# The stubs at /api/auth/nafath/{start,callback} are ready; the integration
# itself is the only thing left to implement.
NAFATH_CLIENT_ID=""
NAFATH_CLIENT_SECRET=""
NAFATH_AUTH_URL=""
NAFATH_TOKEN_URL=""
NAFATH_JWKS_URL=""

# --- Gmail OAuth (optional, per-office Gmail send) ---
# Admins connect the office Gmail account at /settings -> Integrations
# (B1b UI). After consent, invitations can be sent as that mailbox via
# the Gmail API instead of a generic SendGrid/Resend relay.
#
# Setup:
#   1. In Google Cloud Console create an OAuth 2.0 Client ID (type:
#      Web application). Add the redirect URI below to its authorized
#      redirect URIs list. Verify the consent screen lists ONLY the
#      gmail.send + openid + email scopes — widening would require a
#      re-review by Google.
#   2. Encryption key — 32 raw bytes, base64 encoded:
#        openssl rand -base64 32
#      This key encrypts access+refresh tokens at rest in Postgres.
#      DISTINCT FROM SESSION_SECRET on purpose (see src/lib/secrets.ts
#      for the key-separation rationale).
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/oauth/google/callback"
OAUTH_ENCRYPTION_KEY=""

# --- Observability ---
HEALTH_REQUIRE_DB="false"            # flip to "true" once DATABASE_URL is wired, so Railway catches DB outages

# --- Server action hardening (optional) ---
# Comma-separated origins that may POST server actions. Defaults to same-origin.
ALLOWED_ORIGINS=""

# --- Webhook (delivery status inbound) ---
# Leave empty to disable /api/webhooks/delivery. HMAC-SHA256 of the raw body,
# hex-encoded, must match x-signature header. Generate: openssl rand -hex 32.
WEBHOOK_SIGNING_SECRET=""

# --- Cron / scheduled stages ---
# Bearer token required by /api/cron/tick. Any scheduler can call the endpoint
# on a minute-ish cadence (Railway cron, Vercel cron, cron-job.org, GH Actions).
# Leave empty to disable scheduled stages. Generate: openssl rand -hex 32.
CRON_SECRET=""

# --- Teams (optional) ---
# When "true", the Teams feature is exposed: admins can create org units,
# assign members, and scope campaigns. For single-desk tenants, leave unset.
TEAMS_ENABLED=""

# --- Inbound reply handling ---
# Reply-To on outgoing invitations becomes rsvp+<token>@<this-domain>.
# Requires MX records on that domain pointing at an inbound-parse
# service (SendGrid Inbound Parse, Mailgun Routes, Postmark Inbound,
# AWS SES). Empty disables reply-to-RSVP; sending still works.
INBOUND_EMAIL_DOMAIN=""

# Shared bearer token required on POSTs to /api/webhooks/inbound/*.
# Send it as the "x-inbound-secret" header (or ?key= query param for
# SMS providers that can't add custom headers). Generate with
# `openssl rand -hex 32`.
INBOUND_WEBHOOK_SECRET=""

# When a reply is confidently parsed as attending/declined/stop AND we
# can match the sender to a known invitee, send a one-line bilingual
# acknowledgment back on the same channel. Set to "false" to disable.
INBOUND_AUTO_ACK="true"

# --- Approval workflow ---
# Sends touching more than this many recipients require an admin to
# approve them at /approvals. Admins bypass the gate. Default 100.
APPROVAL_THRESHOLD="100"

# --- Daily digest ---
# When true, /api/cron/tick also fires a once-per-day deliverability
# summary to every admin at DIGEST_HOUR (APP_TIMEZONE local). Idempotent
# via an eventLog row keyed on the local date, so duplicate cron calls
# are safe. Opt-in — leave unset on quiet offices.
DELIVERABILITY_DIGEST=""
DIGEST_HOUR="7"

# --- Email provider (choose one, leave others blank) ---
# "gmail" reuses the GOOGLE_OAUTH_* block above and sends AS the
# mailbox that an admin connected at /settings (B1b). The
# EMAIL_FROM env var is IGNORED when EMAIL_PROVIDER=gmail — the
# From address is the connected googleEmail, because Gmail 400s on
# any other sender. EMAIL_FROM_NAME is still respected for display.
EMAIL_PROVIDER="stub"                # stub | sendgrid | resend | gmail
EMAIL_FROM="no-reply@example.gov.sa"
EMAIL_FROM_NAME="Protocol Office"
SENDGRID_API_KEY=""
RESEND_API_KEY=""

# --- SMS provider ---
# Valid values: stub | twilio | unifonic | msegat | taqnyat | whatsapp-twilio
# (whatsapp-twilio is a legacy alias for WhatsApp session-text sends
# via the SMS channel; new WhatsApp work should use WHATSAPP_PROVIDER
# below instead.)
SMS_PROVIDER="stub"
SMS_SENDER_ID="GOV"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
# WhatsApp via Twilio reuses the same SID + auth token. Set WHATSAPP_FROM
# to the E.164 number enrolled in your WhatsApp Business sender profile
# (no "whatsapp:" prefix — we add it when dispatching).
WHATSAPP_FROM=""
UNIFONIC_APP_SID=""
UNIFONIC_SENDER_NAME=""
MSEGAT_API_KEY=""
MSEGAT_USERNAME=""
# Taqnyat (SA) SMS channel. Bearer-token auth; TAQNYAT_SMS_SENDER is
# an account-provisioned short name Taqnyat validates server-side.
TAQNYAT_SMS_TOKEN=""
TAQNYAT_SMS_SENDER=""

# --- WhatsApp provider (distinct channel from SMS) ---
# WHATSAPP_PROVIDER=taqnyat sends via Taqnyat's WhatsApp Business API
# with template discipline and session-window awareness (see
# src/lib/providers/whatsapp/taqnyat.ts). Default is "stub" so the
# workspace/chat surfaces WhatsApp without sending until wired.
WHATSAPP_PROVIDER="stub"             # stub | taqnyat
TAQNYAT_WHATSAPP_TOKEN=""
# Optional — only set if your Taqnyat account exposes a template
# namespace for outbound template messages. Safe to leave empty.
TAQNYAT_WHATSAPP_TEMPLATE_NAMESPACE=""

# Taqnyat delivery-status webhook shared bearer. Used by
# /api/webhooks/taqnyat/delivery/{sms,whatsapp} to validate DLR
# callbacks. Distinct from WEBHOOK_SIGNING_SECRET (generic HMAC
# delivery relay) and INBOUND_WEBHOOK_SECRET (inbound-parse). Leave
# empty to disable the Taqnyat DLR routes (they 503 not_configured
# fail-closed). Generate: openssl rand -hex 32.
TAQNYAT_WEBHOOK_SECRET=""

# --- Locale ---
DEFAULT_LOCALE="en"                  # en | ar
DEFAULT_COUNTRY="SA"

# --- AI runtime (P1/P2) ---
# `/api/chat` picks one AI backend per request via `resolveRuntime`.
# The route emits HTTP 503 with a typed `error` code if the selected
# backend is missing credentials or is unknown (see
# `src/app/api/chat/runtime-gate.ts` + `tests/unit/chat-route-runtime.test.ts`).
#
# Values:
#   AI_RUNTIME=anthropic   (default)  — uses ANTHROPIC_API_KEY below.
#                                       Supports prompt caching.
#   AI_RUNTIME=openrouter             — uses OPENROUTER_* below. Does NOT
#                                       support prompt caching (dropped
#                                       silently; documented trade-off).
#
# Anthropic (default path):
AI_RUNTIME="anthropic"
ANTHROPIC_API_KEY=""

# OpenRouter (optional; required only when AI_RUNTIME=openrouter):
# - OPENROUTER_MODEL is namespaced (e.g. `anthropic/claude-sonnet-4.6`,
#   `openai/gpt-4o`). The chat route's internal model id is IGNORED on
#   this path — the runtime substitutes this value per request.
# - OPENROUTER_HTTP_REFERER + OPENROUTER_X_TITLE are optional analytics
#   headers OpenRouter uses to populate their dashboard.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL=""
OPENROUTER_HTTP_REFERER=""
OPENROUTER_X_TITLE=""
